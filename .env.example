# ==============================================================================
# Environment Configuration Template for AI Image Generation Bot
# Rename this file to .env and fill in your actual credentials.
# DO NOT commit your actual .env file with secrets to version control!
# ==============================================================================

# Telegram Bot API Token
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key
# Used for DALL-E 3 image generation. Get this from platform.openai.com.
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini / MakerSuite API Key
# If using Gemini directly via API or HTTP nodes in n8n.
GEMINI_API_KEY=your_gemini_api_key_here

# n8n Configuration (Optional)
# If self-hosting, configure these as needed.
N8N_PORT=5678
N8N_ENCRYPTION_KEY=generate_a_random_secure_key_here
